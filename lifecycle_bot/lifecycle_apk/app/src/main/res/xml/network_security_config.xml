<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config for LifecycleBot

    By default Android 9+ blocks cleartext HTTP traffic.
    Solana RPC nodes are almost always HTTPS, but some self-hosted nodes
    and local devnet configurations use HTTP. This config allows cleartext
    only for known RPC/API domains while keeping HTTPS enforced everywhere else.

    Dexscreener, Birdeye, Rugcheck, Jupiter, and Helius are all HTTPS only.
    The cleartext exception is purely for custom RPC node configurations.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext only for user-configured custom RPC nodes -->
    <!-- Production Solana RPCs (mainnet-beta) are all HTTPS -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
