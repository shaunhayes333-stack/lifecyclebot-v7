<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#06080C"
    android:padding="@dimen/card_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── CONNECTION STATUS ── -->
        <LinearLayout style="@style/Card" android:orientation="vertical">
            <TextView style="@style/CardLabel" android:text="WALLET CONNECTION"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/card_margin_bottom">
                <TextView android:id="@+id/tvConnectionStatus"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="● DISCONNECTED" android:textColor="#4A5E70"
                    android:textSize="13sp" android:fontFamily="monospace" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Connected view -->
            <LinearLayout android:id="@+id/layoutConnected"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <TextView style="@style/KpiLabel" android:text="PUBLIC KEY"/>
                <TextView android:id="@+id/tvPublicKey"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#DCE8F0" android:textSize="12sp"
                    android:fontFamily="monospace" android:layout_marginBottom="@dimen/card_margin_bottom"
                    android:textIsSelectable="true"/>

                <Button android:id="@+id/btnDisconnect"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="DISCONNECT WALLET"
                    android:backgroundTint="#FF3D5A" android:textColor="#FFFFFF"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Disconnected view -->
            <LinearLayout android:id="@+id/layoutDisconnected"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="visible">

                <TextView style="@style/FieldLabel" android:text="PRIVATE KEY (base58)"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <EditText android:id="@+id/etPrivKeyInput" style="@style/Input"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:hint="Enter base58 private key…"
                        android:inputType="textPassword"/>
                    <Button android:id="@+id/btnShowHideKey"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Show" android:textSize="11sp"
                        android:backgroundTint="#111720" android:textColor="#4A5E70"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="⚠ Use a dedicated burner wallet only. Never your main wallet."
                    android:textColor="#FFB700" android:textSize="11sp"
                    android:fontFamily="monospace" android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp"/>

                <Button android:id="@+id/btnChangeKey"
                    style="@style/BtnSecondary"
                    android:text="Change Key"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <Button android:id="@+id/btnConnect"
                    android:layout_width="match_parent" android:layout_height="@dimen/bottom_bar_button_height"
                    android:text="CONNECT WALLET"
                    android:backgroundTint="#00E5A0" android:textColor="#000000"
                    android:textStyle="bold" android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── BALANCE ── -->
        <LinearLayout style="@style/Card" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView style="@style/CardLabel" android:text="BALANCE"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_marginBottom="0dp"/>
                <Button android:id="@+id/btnRefreshBalance"
                    android:layout_width="wrap_content" android:layout_height="32dp"
                    android:text="↻" android:textSize="16sp"
                    android:backgroundTint="#111720" android:textColor="#4A5E70"
                    android:paddingStart="12dp" android:paddingEnd="12dp"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1A2232" android:layout_marginBottom="@dimen/card_margin_bottom" android:layout_marginTop="6dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView style="@style/KpiLabel" android:text="SOL BALANCE"/>
                    <TextView android:id="@+id/tvSolBalance"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#00E5A0"
                        android:textSize="@dimen/balance_text_size" android:fontFamily="monospace" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView style="@style/KpiLabel" android:text="USD VALUE"/>
                    <TextView android:id="@+id/tvUsdBalance"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#DCE8F0"
                        android:textSize="@dimen/balance_text_size" android:fontFamily="monospace" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="@dimen/inner_gap">
                <TextView android:id="@+id/tvSolPrice"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—" android:textColor="#4A5E70"
                    android:textSize="11sp" android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvLastRefreshed"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="" android:textColor="#4A5E70"
                    android:textSize="11sp" android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── P&L CHART ── -->
        <LinearLayout style="@style/Card" android:orientation="vertical">
            <TextView style="@style/CardLabel" android:text="CUMULATIVE P&amp;L"/>

            <!-- P&L headline numbers -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="@dimen/card_margin_bottom">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView style="@style/KpiLabel" android:text="TOTAL P&amp;L"/>
                    <TextView android:id="@+id/tvTotalPnl"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="+0.0000 SOL" android:textColor="#00E5A0"
                        android:textSize="@dimen/token_name_size" android:fontFamily="monospace" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvTotalPnlPct"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="+0.0%" android:textColor="#00E5A0"
                        android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView style="@style/KpiLabel" android:text="RECORD"/>
                    <TextView android:id="@+id/tvTotalTrades"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 trades" android:textColor="#DCE8F0"
                        android:textSize="@dimen/section_title_size" android:fontFamily="monospace"/>
                    <TextView android:id="@+id/tvWinRate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#4A5E70"
                        android:textSize="12sp" android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <!-- The chart -->
            <com.lifecyclebot.ui.PnlChartView
                android:id="@+id/pnlChart"
                android:layout_width="match_parent"
                android:layout_height="@dimen/chart_height"
                android:layout_marginBottom="8dp"/>

            <!-- Best/worst -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1A2232" android:layout_marginTop="4dp" android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tvBestTrade"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Best: —" android:textColor="#00E5A0"
                    android:textSize="12sp" android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvWorstTrade"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Worst: —" android:textColor="#FF3D5A"
                    android:textSize="12sp" android:fontFamily="monospace"
                    android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>


        <!-- ── WITHDRAW FROM TREASURY ── -->
        <LinearLayout style="@style/Card" android:orientation="vertical">
            <TextView style="@style/CardLabel" android:text="WITHDRAW FROM TREASURY"/>

            <!-- Treasury available row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="@dimen/card_margin_bottom">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView style="@style/KpiLabel" android:text="TREASURY LOCKED"/>
                    <TextView android:id="@+id/tvWithdrawTreasuryBal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0.0000◎" android:textColor="#00E5A0"
                        android:textSize="@dimen/token_name_size"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView style="@style/KpiLabel" android:text="TRADEABLE"/>
                    <TextView android:id="@+id/tvWithdrawTradeable"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0.0000◎" android:textColor="#DCE8F0"
                        android:textSize="@dimen/token_name_size"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1A2232" android:layout_marginBottom="@dimen/card_margin_bottom"/>

            <!-- Percentage selector -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView style="@style/KpiLabel" android:text="AMOUNT"
                    android:layout_width="wrap_content" android:layout_marginBottom="0dp"/>
                <TextView android:id="@+id/tvWithdrawPct"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="50%"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/section_title_size"
                    android:fontFamily="monospace" android:textStyle="bold"
                    android:gravity="end"/>
                <TextView android:id="@+id/tvWithdrawSolAmt"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Percentage quick-select buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <Button android:id="@+id/btnWith25"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="25%" android:textSize="12sp" android:textColor="#9CA3AF"
                    android:backgroundTint="#111720" android:layout_marginEnd="4dp"
                    android:fontFamily="monospace"/>
                <Button android:id="@+id/btnWith50"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="50%" android:textSize="12sp" android:textColor="#9CA3AF"
                    android:backgroundTint="#111720" android:layout_marginEnd="4dp"
                    android:fontFamily="monospace"/>
                <Button android:id="@+id/btnWith75"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="75%" android:textSize="12sp" android:textColor="#9CA3AF"
                    android:backgroundTint="#111720" android:layout_marginEnd="4dp"
                    android:fontFamily="monospace"/>
                <Button android:id="@+id/btnWith100"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="100%" android:textSize="12sp" android:textColor="#FF3D5A"
                    android:backgroundTint="#2A0A0A"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Seek bar for fine control -->
            <SeekBar android:id="@+id/seekWithdrawPct"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="100" android:progress="50"
                android:thumbTint="#9945FF" android:progressTint="#9945FF"
                android:progressBackgroundTint="#1F2937"
                android:layout_marginBottom="14dp"/>

            <!-- Destination address -->
            <TextView style="@style/FieldLabel" android:text="DESTINATION ADDRESS (blank = self / bot wallet)"/>
            <EditText android:id="@+id/etWithdrawDest"
                android:layout_width="match_parent" android:layout_height="@dimen/input_height"
                style="@style/Input"
                android:hint="Leave blank to send to your own wallet"
                android:inputType="text" android:maxLines="1"
                android:layout_marginBottom="8dp"/>

            <!-- 100% warning (hidden by default) -->
            <TextView android:id="@+id/tvWithdrawWarning"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="⚠ You are withdrawing 100% of the treasury. The bot will have no locked profit reserve."
                android:textColor="#FFB700" android:textSize="11sp" android:fontFamily="monospace"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- Confirm button -->
            <Button android:id="@+id/btnWithdrawConfirm"
                android:layout_width="match_parent" android:layout_height="@dimen/bottom_bar_button_height"
                android:text="WITHDRAW"
                android:backgroundTint="#9945FF" android:textColor="#FFFFFF"
                android:textStyle="bold" android:fontFamily="monospace"/>

            <!-- Status / result -->
            <TextView android:id="@+id/tvWithdrawStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textColor="#4A5E70"
                android:textSize="12sp" android:fontFamily="monospace"
                android:layout_marginTop="8dp"
                android:minLines="2"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
